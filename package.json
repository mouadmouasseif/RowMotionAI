{
  "name": "rowvision-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components config content i18n lib providers services types scripts next.config.ts --ext .js,.mjs,.ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/check-public-site.mjs && vitest run",
    "test:pwa": "vitest run tests/pwa",
    "test:e2e": "echo Playwright tests require emulator credentials",
    "firebase:emulators": "firebase emulators:start",
    "migrate:athletes:dry": "node --experimental-strip-types scripts/migrate-athletes.ts --dry-run",
    "migrate:athletes": "node --experimental-strip-types scripts/migrate-athletes.ts",
    "migrate:analyses:dry": "node --experimental-strip-types scripts/migrate-analyses.ts --dry-run",
    "migrate:analyses": "node --experimental-strip-types scripts/migrate-analyses.ts",
    "check": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "firebase": "^12.16.0",
    "firebase-admin": "^14.2.0",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.82.0",
    "typescript": "^5.7.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^7.0.0",
    "@testing-library/react": "^16.3.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^15.5.20",
    "jsdom": "^27.0.1",
    "vitest": "^3.2.7"
  }
}
