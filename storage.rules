rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function profile() { return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data; }
    function active() { return signedIn() && profile().active == true; }
    function superAdmin() { return active() && profile().role == "superadmin"; }
    function clubAdminFor(clubId) { return active() && profile().role == "club_admin" && profile().clubId == clubId; }
    function targetProfile(userId) { return firestore.get(/databases/(default)/documents/users/$(userId)).data; }
    function canManageProfile(userId) {
      return active() && (
        request.auth.uid == userId
        || superAdmin()
        || (profile().role == "club_admin" && profile().clubId == targetProfile(userId).clubId)
        || (profile().role == "coach" && targetProfile(userId).role == "athlete" && targetProfile(userId).coachId == request.auth.uid)
      );
    }
    function imageFile() {
      return request.resource != null
        && request.resource.size <= 5 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }
    function competition(competitionId) {
      return firestore.get(/databases/(default)/documents/competitions/$(competitionId)).data;
    }
    function canManageCompetition(competitionId) {
      return active() && (
        superAdmin()
        || competition(competitionId).createdBy == request.auth.uid
        || (profile().role == "club_admin" && profile().clubId == competition(competitionId).clubId)
      );
    }

    match /profile-photos/{userId}/{fileName} {
      allow read: if signedIn();
      allow create, update: if imageFile() && canManageProfile(userId);
      allow delete: if canManageProfile(userId);
    }
    match /clubs/{clubId}/{fileName} {
      allow read: if true;
      allow create, update: if imageFile() && (clubAdminFor(clubId) || superAdmin());
      allow delete: if clubAdminFor(clubId) || superAdmin();
    }
    match /club-logos/{clubId}/{fileName} {
      allow read: if true;
      allow create, update: if imageFile() && (clubAdminFor(clubId) || superAdmin());
      allow delete: if clubAdminFor(clubId) || superAdmin();
    }
    match /competitions/{competitionId}/{fileName} {
      allow read: if true;
      allow create, update: if imageFile() && canManageCompetition(competitionId);
      allow delete: if canManageCompetition(competitionId);
    }
    match /analyses/{ownerId}/{analysisId}/{fileName} {
      allow read: if active() && (request.auth.uid == ownerId || superAdmin());
      allow create, update: if false;
      allow delete: if active() && (request.auth.uid == ownerId || superAdmin());
    }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
